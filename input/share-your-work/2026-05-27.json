    {
        "user": "UJBAJNFLK",
        "type": "message",
        "ts": "1779880697.441419",
        "client_msg_id": "ff92f94b-7279-4a65-8e6d-92b2f03be570",
        "text": "You have to know quite a bit about LLMs to do a good job - as with other powerful tools. And it would help a lot if we had more transparent LLMs, whose learning set could be scrutinized.\n\nPerhaps the two biggest issues with LLMs, other than their huge negative externalities, are opacity and the exceptional ease for using them badly.",
        "team": "T5TCAFTA9",
        "user_team": "T5TCAFTA9",
        "source_team": "T5TCAFTA9",
        "user_profile": {
            "avatar_hash": "e169f54bbaf8",
            "image_72": "https:\/\/avatars.slack-edge.com\/2021-03-12\/1859691333940_e169f54bbaf8b9b36b12_72.png",
            "first_name": "Konrad",
            "real_name": "Konrad Hinsen",
            "display_name": "Konrad Hinsen",
            "team": "T5TCAFTA9",
            "name": "konrad.hinsen",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1779866366.355359",
        "parent_user_id": "UJBAJNFLK",
        "blocks": [
