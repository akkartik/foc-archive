                                "text": "{id 0, type if, test {id 1 ...}, then {id 2 ...}, else {id 3 ...} ...}",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": "),\nand not, say, flat list of nodes where ids are idx in that same list?\neg. "
                            },
