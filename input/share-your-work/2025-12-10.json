                                "text": "x. + 1",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " or "
                            },
                            {
                                "type": "text",
                                "text": "if-else [x. = 123] ...",
                                "style": {
                                    "code": true
                                }
