    {
        "user": "UK3LH8CF5",
        "type": "message",
        "ts": "1771878004.584279",
        "client_msg_id": "4d2cc9fa-64a6-4e79-869f-9b491a064d3d",
        "text": "So at the limit, the whole entire language is just meta rules. Or a tower of meta rules. Meta rules not only see the computation, they can decide to change it. We can change our evaluation order from strict to lazy for example.\n\nMeta rules also can play the rules of macros but at a global level. They are a metaprogram that is given not only the static definition of the code, but all the code at every step in the execution.",
        "team": "T5TCAFTA9",
        "user_team": "T5TCAFTA9",
        "source_team": "T5TCAFTA9",
        "user_profile": {
