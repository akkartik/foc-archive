            "team": "T5TCAFTA9",
            "name": "ak",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1776479270.748729",
        "parent_user_id": "UGWUJUZHT",
        "blocks": [
