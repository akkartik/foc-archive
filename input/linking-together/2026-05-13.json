    {
        "user": "U0ATM0LSFB8",
        "type": "message",
        "ts": "1778656258.176619",
        "client_msg_id": "f475f6ed-8a83-4e91-b91b-e2164b46d46b",
        "text": "That being said, this is adjacent to the issue of an app deciding to store critical bits of data in its proprietary databases that it controls. There was a post related to this shared recently at <https:\/\/www.orionreed.com\/posts\/app-file-topology\/|https:\/\/www.orionreed.com\/posts\/app-file-topology\/>",
        "team": "T5TCAFTA9",
        "user_team": "T5TCAFTA9",
        "source_team": "T5TCAFTA9",
        "user_profile": {
            "avatar_hash": "g79842c7c389",
            "image_72": "https:\/\/secure.gravatar.com\/avatar\/79842c7c389426d76e2bb53fc48f8b98.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0012-72.png",
            "first_name": "dman-os",
            "real_name": "dman-os",
            "display_name": "",
            "team": "T5TCAFTA9",
            "name": "pectin-erased-unit",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1778473180.151529",
        "parent_user_id": "U02E4DAQGSZ",
        "attachments": [
            {
                "image_url": "https:\/\/orionreed.com\/website-embed.png",
                "image_width": 800,
                "image_height": 418,
                "image_bytes": 28423,
                "from_url": "https:\/\/www.orionreed.com\/posts\/app-file-topology\/",
                "service_icon": "https:\/\/www.orionreed.com\/favicon.ico?v=4",
                "id": 1,
                "original_url": "https:\/\/www.orionreed.com\/posts\/app-file-topology\/",
                "fallback": "Digital Topology &amp; Economic Power",
                "text": "The autonomous file, once the basic unit of user agency in personal computing, was first hollowed out through proprietary formats and data internalization, then abolished entirely by cloud platforms, relocating control toward incumbents at each stage. Enclosure succeeds not by offering users less, but by bundling genuine capability gains with topological restructuring, so that the user cannot accept the improvement without accepting the new relationship of power.",
                "title": "Digital Topology &amp; Economic Power",
                "title_link": "https:\/\/www.orionreed.com\/posts\/app-file-topology\/",
                "service_name": "orionreed.com"
            }
        ],
        "blocks": [
