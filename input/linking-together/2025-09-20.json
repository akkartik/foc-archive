                "service_icon": "https:\/\/apisyouwonthate.com\/content\/images\/size\/w256h256\/2023\/03\/apis-logo-square.png",
                "ts": 1506384000,
                "id": 1,
                "original_url": "https:\/\/apisyouwonthate.com\/blog\/api-versioning-has-no-right-way\/",
                "fallback": "APIs You Won't Hate: API Versioning Has No \"Right Way\"",
                "text": "API versioning is a really difficult topic, and sometimes seen as a merely\n\nreligious debate. It’s done differently at different companies, and different\n\nteams within different companies often vary.\n\nSome folks move from approach A to approach B, and when approach B solves their\n\nspecific issues they act like",
                "title": "API Versioning Has No \"Right Way\"",
                "title_link": "https:\/\/apisyouwonthate.com\/blog\/api-versioning-has-no-right-way\/",
                "service_name": "APIs You Won't Hate",
                "fields": [
