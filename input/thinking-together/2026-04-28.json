                                "url": "https:\/\/www.digipres.org\/formats\/mime-types\/#text\/x-emacs-lisp",
                                "text": "text\/x-emacs-lisp",
                                "style": {
                                    "bold": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ") rather idiomatically",
                                "style": {
                                    "bold": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " before you even hit the lexicon stuff.\n\n"
