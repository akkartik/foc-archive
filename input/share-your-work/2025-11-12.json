    {
        "user": "U02E4DAQGSZ",
        "type": "message",
        "ts": "1763020440.784249",
        "client_msg_id": "60e4b03f-eae9-4a64-a9a8-850277da21d5",
        "text": "Kinda difficult to give good feedback. Its way above the level of polish we normally see here, great graphic design, looks very approachable. I have no idea if it works, because I have the curse of knowledge, and its for people without.\nThere is some kind of internal pushback I feel because I do not want AI slop apps shot out like a machine gun, but then the demos are quite encouraging, like a booking form for a sole proprietor tutor. So that made me reflect for a while and think this is kinda of exactly what democratising coding should look like, and maybe whatsapps is exactly the right interface :thinking_face:\nAnyway, it made me think deeply and with so many counter directional views that I left no feedback!\nI think on balance its a great idea and empowering the people to produce their own homegrown software is a great goal. The pricing seems reasonable. I don't like SaaS for the lock in effect, but thats more of a personal philosophy, and anyway, you need a networked presence for whatsapp to work anyway so it does make sense for what it is. I think it comes from a good place. I hope it does well and people use it to build useful things that solve personal problems and not spam. That would be awesome.",
        "team": "T5TCAFTA9",
        "user_team": "T5TCAFTA9",
        "source_team": "T5TCAFTA9",
        "user_profile": {
            "avatar_hash": "27dffd0e73bd",
            "image_72": "https:\/\/avatars.slack-edge.com\/2021-09-13\/2483463922595_27dffd0e73bd6f709927_72.gif",
            "first_name": "Tom",
            "real_name": "Tom Larkworthy",
            "display_name": "Tom Larkworthy",
            "team": "T5TCAFTA9",
            "name": "tom.larkworthy",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1762927513.448719",
        "parent_user_id": "U018S42NMMM",
        "blocks": [
            {
                "type": "rich_text",
                "block_id": "L0tFn",
                "elements": [
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "Kinda difficult to give good feedback. Its way above the level of polish we normally see here, great graphic design, looks very approachable. I have no idea if it works, because I have the curse of knowledge, and its for people without.\nThere is some kind of internal pushback I feel because I do not want AI slop apps shot out like a machine gun, but then the demos are quite encouraging, like a booking form for a sole proprietor tutor. So that made me reflect for a while and think this is kinda of exactly what democratising coding should look like, and maybe whatsapps is exactly the right interface "
                            },
                            {
                                "type": "emoji",
                                "name": "thinking_face",
                                "unicode": "1f914"
                            },
                            {
                                "type": "text",
                                "text": "\nAnyway, it made me think deeply and with so many counter directional views that I left no feedback!\nI think on balance its a great idea and empowering the people to produce their own homegrown software is a great goal. The pricing seems reasonable. I don't like SaaS for the lock in effect, but thats more of a personal philosophy, and anyway, you need a networked presence for whatsapp to work anyway so it does make sense for what it is. I think it comes from a good place. I hope it does well and people use it to build useful things that solve personal problems and not spam. That would be awesome."
                            }
                        ]
                    }
                ]
            }
        ]
    }
]