                        "elements": [
                            {
                                "type": "text",
                                "text": "Vibe-coding your own desktop environment: "
                            },
                            {
                                "type": "link",
                                "url": "https:\/\/isene.org\/2026\/05\/Audience-of-One.html"
                            },
                            {
                                "type": "text",
                                "text": "\nAs "
                            },
                            {
                                "type": "link",
                                "url": "https:\/\/social.skewed.de\/@tiago\/116515533636835286",
                                "text": "this toot"
                            },
                            {
                                "type": "text",
                                "text": " points out, however, this personalization comes at the price of making oneself dependent on a coding agent."
                            }
