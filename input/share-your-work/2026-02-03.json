    {
        "user": "U08HU0GT52A",
        "type": "message",
        "ts": "1770117159.559499",
        "client_msg_id": "ed51bc9b-6e09-4fdc-939a-f31af18fc0d7",
        "text": "A propagator network is different from a usual dataflow network mainly in\nwhat lives at the nodes.\nIn a propagator network (in the sense of Gerald Jay Sussman’s work),\nnodes are autonomous cells that accumulate partial information, rather\nthan variables that are assigned single values.\nDependencies are implicit in the propagation structure, and computation\nproceeds by information growth until a fixed point is reached.",
        "team": "T5TCAFTA9",
        "user_team": "T5TCAFTA9",
        "source_team": "T5TCAFTA9",
        "user_profile": {
            "avatar_hash": "221467034b81",
            "image_72": "https:\/\/avatars.slack-edge.com\/2025-09-08\/9467835379175_221467034b8129ae2050_72.jpg",
            "first_name": "Pandi",
            "real_name": "Pandi Lin",
            "display_name": "",
            "team": "T5TCAFTA9",
            "name": "gtlpd21",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1769970073.454439",
        "parent_user_id": "U08HU0GT52A",
        "blocks": [
            {
                "type": "rich_text",
                "block_id": "L+Kcg",
                "elements": [
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "A propagator network is different from a usual dataflow network mainly in\nwhat lives at the nodes.\nIn a propagator network (in the sense of Gerald Jay Sussman’s work),\nnodes are autonomous cells that accumulate partial information, rather\nthan variables that are assigned single values.\nDependencies are implicit in the propagation structure, and computation\nproceeds by information growth until a fixed point is reached."
                            }
                        ]
                    }
                ]
            }
        ]
