            "display_name": "Tom Larkworthy",
            "team": "T5TCAFTA9",
            "name": "tom.larkworthy",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1758179471.141799",
        "parent_user_id": "U07BD7U4S4R",
        "blocks": [
