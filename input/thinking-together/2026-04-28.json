                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": "\n\nis \""
                            },
                            {
                                "type": "link",
                                "url": "https:\/\/tomlarkworthy.github.io\/lopecode\/notebooks\/atproto.html"
                            },
                            {
                                "type": "text",
                                "text": " \" an SPA when it is also `"
